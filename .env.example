# OpenRouter API key for AI image generation (Gemini 2.5 Flash Image "Nano Banana")
# Get yours at: https://openrouter.ai/keys
# SERVER-SIDE ONLY — set this in Vercel's dashboard (or your .env for local vercel dev)
# Do NOT use the VITE_ prefix — that would bake the key into the client bundle
OPENROUTER_API_KEY=your_openrouter_api_key_here
